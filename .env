# ===========================================
# Variables de Entorno - Curso IA
# ===========================================
# Copia este archivo como .env y completa con tus credenciales:
#   cp .env.example .env
# Docker Compose exige que exista `.env` en la raíz (puede tener valores vacíos si solo abres Jupyter).
#
# IMPORTANTE: Nunca subas el archivo .env al repositorio

# --- GitHub Models API ---
# URLs base para acceder a los modelos de GitHub (no modificar)
OPENAI_BASE_URL="https://models.inference.ai.azure.com"
GITHUB_BASE_URL="https://models.inference.ai.azure.com"
OPENAI_EMBEDDINGS_URL="https://models.github.ai/inference"
ENDPOINT_URL="https://models.inference.ai.azure.com"
# Tu token personal de GitHub con acceso a GitHub Models
# Obtener en: https://github.com/settings/tokens
GITHUB_TOKEN=""
# Modelo usado por los notebooks de agentes. Cambia este valor si un modelo llega
# al limite diario de GitHub Models.
AGENT_MODEL="gpt-4o-mini"

